// AI-Powered YouTube Workflow & Content Management Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  image         String?
  role          String   @default("creator")
  provider      String   @default("credentials")
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  settings UserSetting?

  channels        Channel[]
  videos          Video[]
  projects        Project[]
  tasks           WorkflowTask[]
  notes           Note[]
  folders         Folder[]
  files           FileAsset[]
  notifications   Notification[]
  scripts         Script[]
  analyses        AIAnalysis[]
  recommendations Recommendation[]
  events          ContentEvent[]
  comments        Comment[]
  tokens          VerificationToken[]
  youtubeTokens   YoutubeToken[]
  playlists       Playlist[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserSetting {
  id                 String  @id @default(cuid())
  userId             String  @unique
  theme              String  @default("dark")
  language           String  @default("en")
  aiProvider         String  @default("gemini")
  geminiApiKey       String?
  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(true)
  uploadReminders    Boolean @default(true)
  weeklyReports      Boolean @default(true)
  monthlyReports     Boolean @default(true)
  trendingAlerts     Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Channel {
  id               String  @id @default(cuid())
  userId           String
  youtubeChannelId String?

  title       String
  description String @default("")

  thumbnail String?
  banner    String?
  customUrl String?

  subscriberCount Int @default(0)
  videoCount      Int @default(0)
  viewCount       Int @default(0)
  commentCount    Int @default(0)

  country  String?
  keywords String? @default("[]")

  publishedAt DateTime?

  connected   Boolean @default(false)
  healthScore Int     @default(0)

  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  videos             Video[]
  playlists          Playlist[]
  projects           Project[]
  tasks              WorkflowTask[]
  notes              Note[]
  analyses           AIAnalysis[]
  recommendations    Recommendation[]
  analyticsSnapshots AnalyticsSnapshot[]

  @@index([userId])
}

model Video {
  id String @id @default(cuid())

  userId    String
  channelId String

  youtubeVideoId String?

  title       String
  description String @default("")

  thumbnail String?

  publishedAt DateTime @default(now())

  viewCount    Int @default(0)
  likeCount    Int @default(0)
  commentCount Int @default(0)

  duration        String @default("0:00")
  durationSeconds Int    @default(0)

  tags String @default("[]")

  categoryId String?

  defaultLanguage      String?
  defaultAudioLanguage String?

  licensedContent Boolean @default(false)

  embeddable Boolean @default(true)

  privacyStatus String @default("public")

  isShort Boolean @default(false)

  status String @default("published")

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  comments Comment[]

  @@index([userId])
  @@index([channelId])
}

model Project {
  id        String  @id @default(cuid())
  userId    String
  channelId String?

  name        String
  description String @default("")
  color       String @default("#f43f5e")
  status      String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  channel Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  tasks   WorkflowTask[]
  notes   Note[]
  files   FileAsset[]
  events  ContentEvent[]
  scripts Script[]

  @@index([userId])
}

model YoutubeToken {
  id     String @id @default(cuid())
  userId String

  accessToken  String
  refreshToken String?

  tokenType String
  scope     String

  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Playlist {
  id String @id @default(cuid())

  userId    String
  channelId String

  youtubePlaylistId String?

  title       String
  description String  @default("")
  thumbnail   String?

  itemCount Int @default(0)

  privacyStatus String @default("public")

  publishedAt DateTime @default(now())

  createdAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([channelId])
}

model AnalyticsSnapshot {
  id String @id @default(cuid())

  channelId String

  date DateTime

  views Int @default(0)

  estimatedWatchTimeMinutes Int @default(0)

  averageViewDurationSeconds Float @default(0)

  subscribersGained Int @default(0)

  subscribersLost Int @default(0)

  likes Int @default(0)

  dislikes Int @default(0)

  comments Int @default(0)

  shares Int @default(0)

  estimatedRevenueMicros Int @default(0)

  impressions Int @default(0)

  impressionClicks Int @default(0)

  createdAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, date])
}

model WorkflowTask {
  id        String  @id @default(cuid())
  userId    String
  projectId String?
  channelId String?

  title       String
  description String @default("")

  status   String @default("idea")
  priority String @default("medium")

  deadline DateTime?

  labels String @default("[]")

  order Int @default(0)

  completed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  channel Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

model Note {
  id String @id @default(cuid())

  userId    String
  projectId String?
  channelId String?
  folderId  String?

  title String

  content String @default("")

  tags String @default("[]")

  pinned Boolean @default(false)

  favorited Boolean @default(false)

  archived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  channel Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  folder Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Folder {
  id String @id @default(cuid())

  userId String

  name String

  color String @default("#64748b")

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  notes Note[]

  @@index([userId])
}

model FileAsset {
  id String @id @default(cuid())

  userId String

  projectId String?

  name String

  type String

  mimeType String @default("")

  size Int @default(0)

  url String @default("")

  data String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Notification {
  id     String @id @default(cuid())
  userId String

  type    String
  title   String
  message String

  read Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Script {
  id String @id @default(cuid())

  userId    String
  projectId String?

  title String

  type String @default("full")

  content String @default("")

  metadata String @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model AIAnalysis {
  id String @id @default(cuid())

  userId    String
  channelId String?

  type String

  result String @default("{}")

  score Int @default(0)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  channel Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Recommendation {
  id String @id @default(cuid())

  userId    String
  channelId String?

  type String

  content String @default("{}")

  applied Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  channel Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model ContentEvent {
  id String @id @default(cuid())

  userId    String
  projectId String?

  title String

  date DateTime

  type String @default("publish")

  status String @default("planned")

  notes String @default("")

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Comment {
  id String @id @default(cuid())

  userId  String
  videoId String

  author String @default("Anonymous")

  authorAvatar String?

  text String

  likeCount Int @default(0)

  replyCount Int @default(0)

  sentiment String @default("neutral")

  status String @default("new")

  publishedAt DateTime @default(now())

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([videoId])
  @@index([status])
}

model VerificationToken {
  id String @id @default(cuid())

  userId String

  token String @unique

  type String

  expiresAt DateTime

  used Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}
