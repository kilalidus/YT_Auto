// AI-Powered YouTube Workflow & Content Management Platform
// SQLite datasource — all user data isolated by userId

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  image        String?
  role         String   @default("creator") // creator | admin | editor (RBAC)
  provider     String   @default("credentials") // credentials | google
  emailVerified Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions        Session[]
  channels        Channel[]
  videos          Video[]
  projects        Project[]
  tasks           WorkflowTask[]
  notes           Note[]
  folders         Folder[]
  files           FileAsset[]
  notifications   Notification[]
  scripts         Script[]
  analyses        AIAnalysis[]
  recommendations Recommendation[]
  events          ContentEvent[]
  comments        Comment[]
  tokens          VerificationToken[]
  settings        UserSetting?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserSetting {
  id                  String  @id @default(cuid())
  userId              String  @unique
  theme               String  @default("dark") // dark | light | system
  language            String  @default("en")
  aiProvider          String  @default("gemini") // gemini | openrouter
  geminiApiKey        String?
  emailNotifications  Boolean @default(true)
  pushNotifications   Boolean @default(true)
  uploadReminders     Boolean @default(true)
  weeklyReports       Boolean @default(true)
  monthlyReports      Boolean @default(true)
  trendingAlerts      Boolean @default(true)
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Channel {
  id              String   @id @default(cuid())
  userId          String
  youtubeChannelId String?
  title           String
  description     String   @default("")
  thumbnail       String?
  customUrl       String?
  subscriberCount Int      @default(0)
  videoCount      Int      @default(0)
  viewCount       Int      @default(0)
  country         String?
  publishedAt     DateTime?
  connected       Boolean  @default(false)
  healthScore     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videos          Video[]
  projects        Project[]
  analyses        AIAnalysis[]
  recommendations Recommendation[]

  @@index([userId])
}

model Video {
  id              String   @id @default(cuid())
  userId          String
  channelId       String
  youtubeVideoId  String?
  title           String
  description     String   @default("")
  thumbnail       String?
  publishedAt     DateTime @default(now())
  viewCount       Int      @default(0)
  likeCount       Int      @default(0)
  commentCount    Int      @default(0)
  duration        String   @default("0:00")
  tags            String   @default("[]") // JSON array
  isShort         Boolean  @default(false)
  status          String   @default("published") // published | scheduled | draft
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  comments        Comment[]

  @@index([userId])
  @@index([channelId])
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  channelId   String?
  name        String
  description String   @default("")
  color       String   @default("#f43f5e")
  status      String   @default("active") // active | completed | archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel     Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  tasks       WorkflowTask[]
  notes       Note[]
  files       FileAsset[]
  events      ContentEvent[]

  @@index([userId])
}

model WorkflowTask {
  id          String   @id @default(cuid())
  userId      String
  projectId   String?
  channelId   String?
  title       String
  description String   @default("")
  status      String   @default("idea") // idea | research | script | recording | editing | thumbnail | review | scheduled | published
  priority    String   @default("medium") // low | medium | high | urgent
  deadline    DateTime?
  labels      String   @default("[]") // JSON array
  order       Int      @default(0)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

model Note {
  id         String   @id @default(cuid())
  userId     String
  projectId  String?
  channelId  String?
  folderId   String?
  title      String
  content    String   @default("")
  tags       String   @default("[]") // JSON array
  pinned     Boolean  @default(false)
  favorited  Boolean  @default(false)
  archived   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  folder     Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Folder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#64748b")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes     Note[]

  @@index([userId])
}

model FileAsset {
  id         String   @id @default(cuid())
  userId     String
  projectId  String?
  name       String
  type       String   // image | video | document | thumbnail | audio | asset
  mimeType   String   @default("")
  size       Int      @default(0)
  url        String   @default("")
  data       String?  // base64 for small files
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // upload | recommendation | trending | deadline | weekly | monthly | system
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Script {
  id         String   @id @default(cuid())
  userId     String
  projectId  String?
  title      String
  type       String   @default("full") // full | hook | intro | shorts | podcast | outline | thumbnail
  content    String   @default("")
  metadata   String   @default("{}") // JSON
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AIAnalysis {
  id        String   @id @default(cuid())
  userId    String
  channelId String?
  type      String   // channel | video | audience | seo
  result    String   @default("{}") // JSON
  score     Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Recommendation {
  id        String   @id @default(cuid())
  userId    String
  channelId String?
  type      String   // title | description | seo | tags | keywords | trending | ideas | playlist | uploadtime | engagement | growth | calendar
  content   String   @default("{}") // JSON
  applied   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model ContentEvent {
  id         String   @id @default(cuid())
  userId     String
  projectId  String?
  title      String
  date       DateTime
  type       String   @default("publish") // publish | record | edit | review | meeting
  status     String   @default("planned") // planned | confirmed | done
  notes      String   @default("")
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Comment {
  id           String   @id @default(cuid())
  userId       String
  videoId      String
  author       String   @default("Anonymous")
  authorAvatar String?
  text         String
  likeCount    Int      @default(0)
  replyCount   Int      @default(0)
  sentiment    String   @default("neutral") // positive | neutral | negative
  status       String   @default("new") // new | approved | held | spam | hidden
  publishedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video        Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([videoId])
  @@index([status])
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  type      String   // email_verify | password_reset
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}
